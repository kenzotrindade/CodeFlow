generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

enum FrequencyType {
  DAILY
  WEEKLY
  MONTHLY
}

enum AttemptStatus {
  PENDING
  STARTED
  PASSED
  FAILED
}

model User {
  id        String   @id @default(cuid())

  email     String?  @unique
  password  String?
  name      String?
  image     String?

  githubId  String?  @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts  Account[]
  sessions  Session[]

  preferences UserLanguagePreference[]
  attempts    ExerciseAttempt[]
  exercises   Exercise[]               @relation("UserExercises")
}

model Language {
  id        String   @id @default(cuid())

  name      String   @unique
  slug      String   @unique

  createdAt DateTime @default(now())

  preferences UserLanguagePreference[]
  exercises   Exercise[]
}

model UserLanguagePreference {
  id String @id @default(cuid())

  userId     String
  languageId String

  difficulty Difficulty

  frequencyType  FrequencyType
  frequencyCount Int
  selectedDays   Int[]

  active Boolean @default(true)

  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)

  @@unique([userId, languageId])
}

model Exercise {
  id String @id @default(cuid())

  title          String
  statement      String   @db.Text
  codeSnippet    String?  @db.Text
  expectedOutput String   @db.Text

  difficulty Difficulty

  languageId String
  creatorId  String?

  createdAt DateTime @default(now())

  language Language @relation(fields: [languageId], references: [id], onDelete: Cascade)
  user     User?    @relation("UserExercises", fields: [creatorId], references: [id], onDelete: SetNull)

  attempts ExerciseAttempt[]

  @@index([languageId, difficulty])
}

model ExerciseAttempt {
  id String @id @default(cuid())

  userId     String
  exerciseId String

  submittedCode String?

  status AttemptStatus @default(PENDING)

  replayed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([exerciseId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}